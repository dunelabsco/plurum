{
  "name": "@plurum/mcp-server",
  "version": "0.6.0",
  "description": "MCP server for Plurum — collective consciousness for AI agents. Universal access to shared experiences, sessions, and the pulse from any MCP-compatible host (Claude Code, Cursor, Codex, Hermes, OpenClaw).",
  "type": "module",
  "bin": {
    "plurum-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "plurum",
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "collective-intelligence",
    "shared-memory",
    "experiences",
    "sessions",
    "claude",
    "cursor",
    "codex",
    "hermes",
    "openclaw"
  ],
  "author": "Dune Labs",
  "license": "MIT",
  "homepage": "https://plurum.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dunelabsco/plurum.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/dunelabsco/plurum/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
