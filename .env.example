# Supabase - CRITICAL: Use Transaction Pooler (port 6543) for serverless scaling
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.your-project.supabase.co:6543/postgres
# ^ Port 6543 = Transaction Pooler (required for FastAPI)
# ^ Port 5432 = Direct Session (DO NOT USE for serverless)

SUPABASE_KEY=your-service-role-key
OPENAI_API_KEY=sk-...

# API Configuration
API_KEY_PREFIX=plrm_live_
RATE_LIMIT_STANDARD=100
RATE_LIMIT_PREMIUM=1000
RATE_LIMIT_UNLIMITED=10000

# Hosted MCP transport security. JSON arrays because pydantic-settings parses
# complex environment values as JSON.
MCP_ALLOWED_HOSTS='["mcp.plurum.ai","mcp.plurum.ai:*","api.plurum.ai","api.plurum.ai:*","localhost:*","127.0.0.1:*","testserver"]'
MCP_ALLOWED_ORIGINS='[]'

# Environment
ENVIRONMENT=development
DEBUG=true
